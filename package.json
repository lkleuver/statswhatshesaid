{
  "name": "@statswhatshesaid/next",
  "version": "0.1.0",
  "description": "A super minimal drop-in unique-visitors-per-day stats library for self-hosted Next.js.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "nextjs",
    "stats",
    "analytics",
    "unique-visitors",
    "self-hosted",
    "hyperloglog",
    "privacy",
    "zero-dependencies"
  ],
  "peerDependencies": {
    "next": ">=15.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "next": "^15.2.0",
    "tsup": "^8.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
