{
  "name": "@statswhatshesaid/next",
  "version": "0.0.0",
  "description": "A super minimal drop-in unique-visitors-per-day stats library for self-hosted Next.js.",
  "license": "MIT",
  "author": "Les Kleuver <les.kleuver@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lkleuver/statswhatshesaid.git",
    "directory": "."
  },
  "bugs": {
    "url": "https://github.com/lkleuver/statswhatshesaid/issues"
  },
  "homepage": "https://github.com/lkleuver/statswhatshesaid#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run test && npm run build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run verify && changeset publish",
    "prepublishOnly": "npm run verify"
  },
  "keywords": [
    "nextjs",
    "stats",
    "analytics",
    "unique-visitors",
    "self-hosted",
    "hyperloglog",
    "privacy",
    "zero-dependencies"
  ],
  "peerDependencies": {
    "next": ">=15.2.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^20.14.0",
    "next": "^15.2.0",
    "tsup": "^8.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
